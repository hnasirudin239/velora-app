<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F9FAFB">

    <!-- ========== HEADER (TETAP SAMA) ========== -->
    <LinearLayout
        android:id="@+id/header_layout"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="16dp"
        android:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_arrow_back"
            android:background="@android:color/transparent"
            android:tint="#1F2937"
            android:contentDescription="Kembali" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Detail Produk"
            android:textColor="#1F2937"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />

        <ImageButton
            android:id="@+id/btn_wishlist_header"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_favorite_border"
            android:background="@android:color/transparent"
            android:tint="#1F2937"
            android:contentDescription="Wishlist"
            android:layout_marginEnd="16dp" />

        <ImageButton
            android:id="@+id/btn_share"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_share"
            android:background="@android:color/transparent"
            android:tint="#1F2937"
            android:contentDescription="Bagikan" />
    </LinearLayout>

    <!-- ========== SCROLLABLE CONTENT ========== -->
    <androidx.core.widget.NestedScrollView
        android:id="@+id/nested_scroll_view"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:fillViewport="true"
        app:layout_constraintBottom_toTopOf="@id/bottom_action_bar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header_layout">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- ===== GALERI ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:paddingBottom="12dp">

                <!-- ViewPager2 -->
                <androidx.viewpager2.widget.ViewPager2
                    android:id="@+id/view_pager_images"
                    android:layout_width="match_parent"
                    android:layout_height="250dp"
                    android:layout_marginBottom="12dp" />

                <!-- Thumbnail RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_thumbnails"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:layout_marginBottom="8dp"
                    app:layoutManager="androidx.recyclerview.widget.LinearLayoutManager" />

                <!-- Indicator -->
                <TextView
                    android:id="@+id/tv_gallery_indicator"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="1 / 4"
                    android:textColor="#6B7280"
                    android:textSize="12sp"
                    android:gravity="center"
                    android:textStyle="bold" />
            </LinearLayout>

            <!-- ===== PRODUCT INFO ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:paddingHorizontal="16dp"
                android:paddingTop="16dp"
                android:paddingBottom="12dp"
                android:background="#FFFFFF">

                <!-- Nama -->
                <TextView
                    android:id="@+id/tv_product_name"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sepatu Lari Aerox Premium Edition"
                    android:textColor="#111827"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <!-- Harga -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="8dp">

                    <TextView
                        android:id="@+id/tv_price_current"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 450.000"
                        android:textColor="#DC2626"
                        android:textSize="24sp"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/tv_price_original"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Rp 540.000"
                        android:textColor="#9CA3AF"
                        android:textSize="14sp"
                        android:layout_marginStart="10dp"
                        android:visibility="gone" />

                    <TextView
                        android:id="@+id/tv_discount_badge"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="-16%"
                        android:textColor="#DC2626"
                        android:textSize="11sp"
                        android:textStyle="bold"
                        android:background="#FEF2F2"
                        android:paddingHorizontal="10dp"
                        android:paddingVertical="2dp"
                        android:layout_marginStart="8dp"
                        android:visibility="gone" />
                </LinearLayout>

                <!-- Rating & Terjual -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    >

                    <RatingBar
                        android:id="@+id/rb_rating"
                        style="@style/Widget.AppCompat.RatingBar.Small"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:isIndicator="true"
                        android:numStars="5"
                        android:stepSize="0.1"
                        android:progressTint="#FBBF24" />

                    <TextView
                        android:id="@+id/tv_rating_value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4.8"
                        android:textColor="#4B5563"
                        android:textSize="13sp"
                        android:textStyle="bold"
                        android:layout_marginStart="4dp" />

                    <View
                        android:layout_width="1dp"
                        android:layout_height="12dp"
                        android:background="#E5E7EB"
                        android:layout_marginHorizontal="10dp" />

                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        android:gravity="center_vertical">

                        <ImageView
                            android:layout_width="14dp"
                            android:layout_height="14dp"
                            android:src="@drawable/ic_fire"
                            android:tint="#F97316" />

                        <TextView
                            android:id="@+id/tv_sold_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Terjual 3.245+"
                            android:textColor="#4B5563"
                            android:textSize="13sp"
                            android:layout_marginStart="4dp" />
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ===== VARIANTS ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginTop="8dp">

                <!-- Varian Warna -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:layout_marginBottom="16dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pilih Varian Warna"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/color_options"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        >
                        <!-- Dinamis di code -->
                    </LinearLayout>
                </LinearLayout>

                <!-- Varian Ukuran -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Pilih Ukuran"
                        android:textColor="#374151"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        android:layout_marginBottom="8dp" />

                    <LinearLayout
                        android:id="@+id/size_options"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal"
                        >
                        <!-- Dinamis di code -->
                    </LinearLayout>
                </LinearLayout>
            </LinearLayout>

            <!-- ===== DESCRIPTION ===== -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginTop="8dp"
                android:layout_marginBottom="80dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="📝 Deskripsi Produk"
                    android:textColor="#111827"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:layout_marginBottom="8dp" />

                <TextView
                    android:id="@+id/tv_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Sepatu lari dengan teknologi Air Cushion terbaru. Desain modern yang cocok untuk aktivitas sehari-hari maupun olahraga intensif. Tersedia dalam berbagai pilihan warna eksklusif.\n\nSpesifikasi:\n- Material: Mesh breathable dan synthetic leather\n- Sol: Karet premium anti-slip\n- Berat: 280g (ringan)"
                    android:textColor="#4B5563"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp" />
            </LinearLayout>

            <!-- ===== REVIEW SECTION ===== -->
            <LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
                xmlns:app="http://schemas.android.com/apk/res-auto"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:background="#FFFFFF"
                android:padding="16dp"
                android:layout_marginTop="8dp"
                android:elevation="2dp"
                app:cardCornerRadius="14dp">

                <!-- Header -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:layout_marginBottom="12dp">


                    <TextView
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:text="⭐ Ulasan"
                        android:textColor="#111827"
                        android:textSize="16sp"
                        android:textStyle="bold" />

                        <TextView
                            android:id="@+id/tv_review_count"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text=" (124)"
                            android:visibility="gone"
                            android:textColor="#6B7280"
                            android:textSize="14sp"
                            android:textStyle="normal" />

                   

                    <!-- Filter Pills -->
                    <LinearLayout
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <TextView
                            android:id="@+id/filter_all"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Semua"
                            android:textColor="#1A73E8"
                            android:textSize="12sp"
                            android:textStyle="bold"
                            android:background="@drawable/bg_filter_pill_active"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="6dp"
                            android:clickable="true"
                            android:focusable="true" />

                        <TextView
                            android:id="@+id/filter_media"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Bergambar dan Video"
                            android:textColor="#4B5563"
                            android:textSize="12sp"
                            android:background="@drawable/bg_filter_pill_inactive"
                            android:paddingHorizontal="14dp"
                            android:paddingVertical="6dp"
                            android:layout_marginStart="8dp"
                            android:clickable="true"
                            android:focusable="true" />
                    </LinearLayout>
                </LinearLayout>

                <!-- Review RecyclerView -->
                <androidx.recyclerview.widget.RecyclerView
                    android:id="@+id/rv_reviews"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:nestedScrollingEnabled="false" />

            </LinearLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- ========== BOTTOM ACTION BAR ========== -->
    <LinearLayout
        android:id="@+id/bottom_action_bar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="#FFFFFF"
        android:elevation="8dp"
        android:orientation="horizontal"
        android:paddingHorizontal="20dp"
        android:paddingVertical="10dp"
        android:gravity="center_vertical"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent">

         <!-- Tombol Wishlist -->
        <ImageButton
            android:id="@+id/btn_wishlist"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="@drawable/bg_wishlist_button"
            android:src="@drawable/ic_favorite_border"
            android:scaleType="centerInside"
            android:contentDescription="Wishlist" />

        <Button
            android:id="@+id/btn_buy"
            android:layout_width="0dp"
            android:layout_height="55dp"
            android:layout_weight="1"
            android:text="🛒 Beli Sekarang"
            android:textAllCaps="false"
            android:textSize="16sp"
            android:textStyle="bold"
            android:textColor="#FFFFFF"
            android:backgroundTint="#1A73E8"
            android:drawableTint="#FFFFFF"
            android:drawablePadding="8dp" />

    </LinearLayout>

    <!-- FAB Tulis Review -->
    <com.google.android.material.floatingactionbutton.FloatingActionButton
        android:id="@+id/fab_write_review"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="16dp"
        android:src="@drawable/ic_add_review"
        app:backgroundTint="#1A73E8"
        app:tint="#FFFFFF"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/bottom_action_bar"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>