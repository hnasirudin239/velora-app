<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:background="#FFFFFF"
    android:paddingHorizontal="20dp"
    android:paddingTop="20dp"
    android:paddingBottom="16dp"
    android:elevation="8dp">

    <!-- Handle / Drag Indicator -->
    <View
        android:layout_width="40dp"
        android:layout_height="4dp"
        android:layout_gravity="center"
        android:background="#D1D5DB"
        android:layout_marginBottom="16dp" />

    <!-- Title -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="🎟️ Pilih Voucher"
        android:textColor="#111827"
        android:textSize="20sp"
        android:textStyle="bold"
        android:layout_marginBottom="4dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Pilih voucher yang ingin digunakan"
        android:textColor="#6B7280"
        android:textSize="14sp"
        android:layout_marginBottom="16dp" />

    <!-- Divider -->
    <View
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#F3F4F6"
        android:layout_marginBottom="16dp" />

    <!-- Voucher List -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_voucher_list"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:nestedScrollingEnabled="false"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btn_apply"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:backgroundTint="#1A73E8"
        android:text="Gunakan Voucher"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />


    <!-- Cancel Button -->
    <Button
        android:id="@+id/btn_cancel"
        android:layout_width="match_parent"
        android:layout_height="48dp"
        android:backgroundTint="#F3F4F6"
        android:text="Batal"
        android:textColor="#4B5563"
        android:textSize="14sp"
        android:textStyle="bold" />

</LinearLayout>