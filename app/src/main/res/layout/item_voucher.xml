<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="14dp"
    app:cardCornerRadius="14dp"
    app:cardElevation="2dp"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:background="#FFFFFF"
        android:clipChildren="false"
        android:clipToPadding="false">

        <!-- ===== LEFT SIDE (Discount) ===== -->
        <LinearLayout
            android:id="@+id/ll_left"
            android:layout_width="100dp"
            android:layout_height="match_parent"
            android:minHeight="120dp"
            android:orientation="vertical"
            android:gravity="center"
            android:padding="16dp"
            android:background="@drawable/bg_voucher_money"
            android:clipChildren="false"
            android:clipToPadding="false">

            <TextView
                android:id="@+id/tv_discount_amount"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Rp 50K"
                android:textColor="#DC2626"
                android:textSize="28sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_discount_label"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Diskon Belanja"
                android:textColor="#DC2626"
                android:textSize="12sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_min_spend"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Min. 250K"
                android:textColor="#DC2626"
                android:textSize="10sp" />
        </LinearLayout>

        <!-- ===== RIGHT SIDE (Info) ===== -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical"
            android:padding="16dp"
            android:gravity="center_vertical">

            <TextView
                android:id="@+id/tv_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Voucher Belanja Akhir Bulan"
                android:textColor="#111827"
                android:textSize="15sp"
                android:textStyle="bold" />

            <!-- Code Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:paddingVertical="6dp"
                android:layout_marginTop="6dp"
                android:backgroundTint="#F9FAFB"
                android:background="@drawable/bg_code_row">

                <TextView
                    android:id="@+id/tv_code"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="NEURO50K"
                    android:textColor="#1A73E8"
                    android:textSize="13sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.5" />

                <TextView
                    android:id="@+id/tv_copy"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Salin"
                    android:textColor="#1A73E8"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    android:background="#EFF6FF"
                    android:paddingHorizontal="10dp"
                    android:paddingVertical="4dp"
                    android:clickable="true"
                    android:focusable="true" />
            </LinearLayout>

            <!-- Meta: Expiry & Status -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="horizontal"
                    android:gravity="center_vertical">

                    <ImageView
                        android:layout_width="12dp"
                        android:layout_height="12dp"
                        android:src="@drawable/ic_order_history"
                        android:tint="#6B7280" />

                    <TextView
                        android:id="@+id/tv_expiry"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Berlaku s/d 15 Jul 2026"
                        android:textColor="#6B7280"
                        android:textSize="11sp"
                        android:layout_marginStart="4dp" />
                </LinearLayout>

                <TextView
                    android:id="@+id/tv_status"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Tersedia"
                    android:textColor="#047857"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:background="#D1FAE5"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="2dp" />
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</androidx.cardview.widget.CardView>