<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp"
    app:cardCornerRadius="12dp"
    app:cardElevation="2dp"
    android:foreground="?android:attr/selectableItemBackground">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="12dp"
        android:background="#FFFFFF"
        android:gravity="center_vertical">

        <!-- Icon -->
        <FrameLayout
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:background="@drawable/bg_voucher_money"
            android:layout_marginEnd="12dp">

            <TextView
                android:id="@+id/tv_voucher_discount_modal"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="center"
                android:text="50K"
                android:textColor="#DC2626"
                android:textSize="14sp"
                android:textStyle="bold" />
        </FrameLayout>

        <!-- Info -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tv_voucher_title_modal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Voucher Belanja Akhir Bulan"
                android:textColor="#111827"
                android:textSize="14sp"
                android:textStyle="bold" />

            <TextView
                android:id="@+id/tv_voucher_code_modal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="NEURO50K"
                android:textColor="#6B7280"
                android:textSize="12sp" />

            <TextView
                android:id="@+id/tv_voucher_min_spend_modal"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Min. Belanja Rp 250.000"
                android:textColor="#9CA3AF"
                android:textSize="11sp" />
        </LinearLayout>

        <!-- Radio Button -->
        <RadioButton
            android:id="@+id/rb_select_voucher"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:buttonTint="#1A73E8" />

    </LinearLayout>
</androidx.cardview.widget.CardView>